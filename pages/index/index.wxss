.page-container {
  min-height: 100vh;
  background: #f6f7fb;
  padding-bottom: 24rpx;
}

.search-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 18rpx 24rpx;
  background: #fff;
  box-shadow: 0 1rpx 0 rgba(31, 35, 41, 0.06);
}

.search-box {
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #f1f3f7;
}

.search-icon {
  width: 36rpx;
  color: #8a8f99;
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  color: #1f2329;
  font-size: 28rpx;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8f99;
  font-size: 36rpx;
}

.hero-section {
  margin: 18rpx 24rpx;
  padding: 30rpx 28rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #fff2df 0%, #ffe1d2 54%, #ffd2a8 100%);
}

.hero-copy {
  display: flex;
  flex-direction: column;
}

.hero-title {
  color: #1f2329;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-subtitle {
  max-width: 470rpx;
  margin-top: 8rpx;
  color: #5f6570;
  font-size: 24rpx;
  line-height: 36rpx;
}

.hero-mark {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  font-size: 56rpx;
}

.hot-section {
  background: #fff;
  margin-bottom: 16rpx;
  padding: 22rpx 0 24rpx;
}

.section-head {
  padding: 0 24rpx 18rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.section-title {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 700;
}

.section-note {
  color: #8a8f99;
  font-size: 24rpx;
}

.hot-scroll {
  width: 100%;
  white-space: nowrap;
}

.hot-item {
  width: 176rpx;
  margin-left: 24rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  vertical-align: top;
}

.hot-item:last-child {
  margin-right: 24rpx;
}

.hot-icon-box {
  width: 132rpx;
  height: 132rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f3f7;
  font-size: 56rpx;
}

.hot-name {
  width: 100%;
  margin-top: 12rpx;
  color: #1f2329;
  font-size: 25rpx;
  font-weight: 600;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-price {
  margin-top: 4rpx;
  color: #ff6a2a;
  font-size: 28rpx;
  font-weight: 700;
}

.category-bar,
.tag-filter {
  width: 100%;
  white-space: nowrap;
  background: #fff;
}

.category-bar {
  padding: 8rpx 18rpx;
}

.category-item {
  min-width: 126rpx;
  height: 92rpx;
  margin-right: 8rpx;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #5f6570;
}

.category-item.active {
  background: #fff0e8;
  color: #ff6a2a;
  font-weight: 600;
}

.category-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.category-name {
  max-width: 110rpx;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-filter {
  padding: 12rpx 20rpx 16rpx;
  margin-bottom: 16rpx;
}

.tag-chip {
  height: 52rpx;
  min-width: 96rpx;
  margin-right: 12rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f1f3f7;
  color: #5f6570;
  font-size: 24rpx;
}

.tag-chip.active {
  background: #ff6a2a;
  color: #fff;
}

.food-list {
  padding: 0 20rpx;
}

.search-results {
  padding-top: 16rpx;
}

.food-card {
  min-height: 164rpx;
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.04);
}

.food-icon {
  width: 122rpx;
  height: 122rpx;
  margin-right: 18rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #f1f3f7;
  font-size: 52rpx;
}

.food-info {
  flex: 1;
  min-width: 0;
}

.food-name {
  color: #1f2329;
  font-size: 31rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-meta {
  min-height: 36rpx;
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.food-tag {
  max-width: 132rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #fff0e8;
  color: #ff6a2a;
  font-size: 21rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-sales {
  color: #8a8f99;
  font-size: 22rpx;
}

.food-price {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  color: #ff6a2a;
  font-size: 24rpx;
  font-weight: 700;
}

.price-value {
  color: #ff6a2a;
  font-size: 36rpx;
  font-weight: 800;
}

.price-old {
  margin-left: 10rpx;
  color: #a8adb7;
  font-size: 23rpx;
  text-decoration: line-through;
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  margin-left: 16rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #ff6a2a;
  color: #fff;
  font-size: 38rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 20rpx rgba(255, 106, 42, 0.24);
}

.load-more {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff6a2a;
  font-size: 26rpx;
}

.c-1 {
  background: #ffe7dc;
}

.c-2 {
  background: #e4f3ff;
}

.c-3 {
  background: #e8f5e9;
}

.c-4 {
  background: #fff4c6;
}
