/* pages/index/index.wxss — 点餐首页 */

.page-container {
  padding-bottom: 20rpx;
  background: #f8f8f8;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
}

.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 26rpx; }
.search-clear { font-size: 32rpx; color: #ccc; padding: 4rpx 8rpx; }

/* 热销区域 */
.hot-section {
  background: linear-gradient(135deg, #fff 0%, #fff8f5 100%);
  padding: 24rpx 24rpx 0;
  margin-bottom: 8rpx;
}

.hot-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.hot-icon { margin-right: 8rpx; font-size: 36rpx; }

.hot-scroll { white-space: nowrap; overflow-x: auto; padding-bottom: 24rpx; -webkit-overflow-scrolling: touch; }

.hot-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 220rpx;
  margin-right: 20rpx;
  white-space: normal;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.hot-item:active { transform: scale(0.96); }

.hot-image-wrap {
  width: 160rpx; height: 160rpx; border-radius: 16rpx;
  position: relative; overflow: hidden;
  background: linear-gradient(135deg, #fff5f0, #ffe8d9);
  display: flex; align-items: center; justify-content: center;
}

.hot-image-placeholder { font-size: 66rpx; }

.hot-tag {
  position: absolute; top: 8rpx; left: 8rpx;
  background: linear-gradient(135deg, #ff5000, #ff7b33);
  color: #fff; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx;
}

.hot-name {
  font-size: 26rpx; font-weight: 600; margin-top: 12rpx;
  text-align: center; width: 100%;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.hot-price { color: #ff5000; font-size: 30rpx; font-weight: 700; margin-top: 6rpx; }
.hot-old-price { color: #bbb; font-size: 22rpx; text-decoration: line-through; }

/* 分类导航 */
.category-bar {
  white-space: nowrap; overflow-x: auto; background: #fff;
  padding: 12rpx 12rpx; margin-bottom: 12rpx;
  -webkit-overflow-scrolling: touch;
}

.category-item {
  display: inline-flex; flex-direction: column; align-items: center;
  padding: 14rpx 22rpx; margin: 0 4rpx; border-radius: 12rpx;
  position: relative;
}

.category-item.active { background: #fff5f0; }

.category-item.active::after {
  content: ''; position: absolute; bottom: 0;
  width: 48rpx; height: 4rpx; background: #ff5000; border-radius: 2rpx;
}

.category-icon { font-size: 40rpx; margin-bottom: 6rpx; }
.category-name { font-size: 24rpx; color: #888; }

.category-item.active .category-name { color: #ff5000; font-weight: 600; }

/* 菜品列表 */
.food-list { padding: 0 20rpx; }

.food-card {
  display: flex; background: #fff; border-radius: 20rpx;
  padding: 20rpx; margin-bottom: 16rpx; position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.food-card:active { transform: scale(0.985); }

.food-image-wrap {
  width: 200rpx; height: 200rpx; border-radius: 16rpx;
  flex-shrink: 0; position: relative; overflow: hidden;
  background: linear-gradient(145deg, #fff8f5, #ffe8d9);
  display: flex; align-items: center; justify-content: center;
}

.food-image-placeholder {
  font-size: 76rpx; width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
}

.food-tag {
  position: absolute; top: 10rpx; left: 10rpx;
  background: linear-gradient(135deg, #ff5000, #ff7b33);
  color: #fff; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx;
}

.food-info {
  flex: 1; margin-left: 20rpx; display: flex; flex-direction: column;
  justify-content: space-between; padding-right: 66rpx; padding-top: 4rpx; padding-bottom: 4rpx;
}

.food-name { font-size: 30rpx; font-weight: 700; color: #222; margin-bottom: 4rpx; line-height: 1.3; }
.food-desc { font-size: 24rpx; color: #999; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.food-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
.food-price { display: flex; align-items: baseline; }

.price-symbol { color: #ff5000; font-size: 24rpx; font-weight: 700; }
.price-value { color: #ff5000; font-size: 38rpx; font-weight: 700; }
.price-old { color: #bbb; font-size: 22rpx; text-decoration: line-through; margin-left: 8rpx; }

.food-meta { display: flex; flex-direction: column; align-items: flex-end; }
.food-rating { color: #ff8c00; font-size: 22rpx; font-weight: 500; }
.food-sales { color: #bbb; font-size: 20rpx; margin-top: 4rpx; }

/* 加购按钮 */
.add-btn {
  position: absolute; right: 20rpx; bottom: 24rpx;
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: linear-gradient(135deg, #ff5000, #ff7b33);
  color: #fff; font-size: 40rpx; font-weight: 300;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(255, 80, 0, 0.3);
  z-index: 10;
}

.add-btn:active { transform: scale(0.9); box-shadow: 0 2rpx 8rpx rgba(255,80,0,0.4); }

/* 搜索结果 */
.search-results { padding-top: 12rpx; }
.food-grid { display: flex; flex-wrap: wrap; justify-content: space-between; padding: 0 20rpx; }
.food-grid .food-card { width: 47%; flex-direction: column; padding: 0; margin-bottom: 20rpx; }
.food-grid .food-image-wrap { width: 100%; height: 260rpx; border-radius: 20rpx 20rpx 0 0; }
.food-grid .food-info { padding: 16rpx 16rpx 20rpx; margin-left: 0; padding-right: 16rpx; }
.food-grid .add-btn { right: 16rpx; bottom: 16rpx; width: 52rpx; height: 52rpx; font-size: 32rpx; }

/* 加载更多 */
.load-more { text-align: center; padding: 32rpx; color: #ff5000; font-size: 26rpx; }
