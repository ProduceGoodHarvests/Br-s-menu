<!--pages/index/index.wxml-->
<view class="page-container">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索菜品..." value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search"/>
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="cancelSearch">✕</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{showSearch}}" class="search-results">
    <view wx:if="{{searchResults.length === 0}}" class="empty-state">
      <text class="empty-icon">🔍</text><text class="empty-text">没有找到相关菜品</text>
    </view>
    <view wx:else class="food-list">
      <view class="food-card" wx:for="{{searchResults}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="food-icon c-{{item.categoryId}}"><text>{{item.icon}}</text></view>
        <view class="food-info">
          <view class="food-name">{{item.name}}</view>
          <view class="food-meta"><text class="food-tag" wx:if="{{item.tag}}">{{item.tag}}</text><text class="food-sales">⭐{{item.rating}}</text></view>
          <view class="food-price"><text class="price-symbol">¥</text><text class="price-value">{{item.price}}</text><text class="price-old" wx:if="{{item.originalPrice > item.price}}">¥{{item.originalPrice}}</text></view>
        </view>
        <view class="add-btn" catchtap="addToCart" data-id="{{item.id}}">+</view>
      </view>
    </view>
  </view>

  <!-- 正常模式 -->
  <view wx:else>
    <view class="hot-section">
      <view class="hot-title"><text class="hot-icon">🔥</text>热销推荐</view>
      <view class="hot-scroll">
        <view class="hot-item" wx:for="{{hotFoods}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="hot-icon-box c-{{item.categoryId}}"><text>{{item.icon}}</text></view>
          <view class="hot-name">{{item.name}}</view>
          <view class="hot-price">¥{{item.price}}</view>
        </view>
      </view>
    </view>

    <view class="category-bar">
      <view class="category-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-id="{{item.id}}">
        <text class="category-icon">{{item.icon}}</text><text class="category-name">{{item.name}}</text>
      </view>
    </view>

    <view class="food-list">
      <view wx:if="{{foodList.length === 0}}" class="empty-state">
        <text class="empty-icon">🍽️</text><text class="empty-text">该分类暂无菜品</text>
      </view>
      <view class="food-card" wx:for="{{foodList}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="food-icon c-{{item.categoryId}}"><text>{{item.icon}}</text></view>
        <view class="food-info">
          <view class="food-name">{{item.name}}</view>
          <view class="food-meta"><text class="food-tag" wx:if="{{item.tag}}">{{item.tag}}</text><text class="food-sales">已售{{item.sales}}</text></view>
          <view class="food-price"><text class="price-symbol">¥</text><text class="price-value">{{item.price}}</text><text class="price-old" wx:if="{{item.originalPrice > item.price}}">¥{{item.originalPrice}}</text></view>
        </view>
        <view class="add-btn" catchtap="addToCart" data-id="{{item.id}}">+</view>
      </view>
      <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">加载更多 ↓</view>
    </view>
  </view>

</view>
