<!--pages/index/index.wxml — 点餐首页-->
<view class="page-container">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索菜品、分类..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="cancelSearch">✕</text>
    </view>
  </view>

  <!-- 搜索中 — 显示搜索结果 -->
  <view wx:if="{{showSearch}}" class="search-results">
    <view wx:if="{{searchResults.length === 0}}" class="empty-state">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">没有找到相关菜品</text>
    </view>
    <view wx:else class="food-grid">
      <view
        class="food-card"
        wx:for="{{searchResults}}"
        wx:key="id"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <view class="food-image-wrap">
          <view class="food-image-placeholder">{{item.icon || '🍽️'}}</view>
          <view class="food-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
        </view>
        <view class="food-info">
          <view class="food-name">{{item.name}}</view>
          <view class="food-desc">{{item.desc}}</view>
          <view class="food-bottom">
            <view class="food-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.price}}</text>
              <text class="price-old" wx:if="{{item.originalPrice > item.price}}">¥{{item.originalPrice}}</text>
            </view>
            <view class="food-sales">已售 {{item.sales}}</view>
          </view>
          <view class="add-btn" catchtap="addToCart" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 正常模式 -->
  <view wx:else>
    <!-- 热销推荐横幅 -->
    <view class="hot-section">
      <view class="hot-title">
        <text class="hot-icon">🔥</text>
        <text>热销推荐</text>
      </view>
      <view class="hot-scroll">
        <view
          class="hot-item"
          wx:for="{{hotFoods}}"
          wx:key="id"
          bindtap="goDetail"
          data-id="{{item.id}}"
        >
          <view class="hot-image-wrap">
            <view class="hot-image-placeholder">{{item.icon || '🍽️'}}</view>
            <view class="hot-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
          </view>
          <view class="hot-name">{{item.name}}</view>
          <view class="hot-price">¥{{item.price}}</view>
          <view wx:if="{{item.originalPrice > item.price}}" class="hot-old-price">¥{{item.originalPrice}}</view>
        </view>
      </view>
    </view>

    <!-- 分类导航 -->
    <view class="category-bar">
      <view
        class="category-item {{activeCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="switchCategory"
        data-id="{{item.id}}"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>

    <!-- 菜品列表 -->
    <view class="food-list">
      <view wx:if="{{foodList.length === 0}}" class="empty-state">
        <text class="empty-icon">🍽️</text>
        <text class="empty-text">该分类暂无菜品</text>
      </view>
      <block wx:for="{{foodList}}" wx:key="id">
        <view class="food-card" bindtap="goDetail" data-id="{{item.id}}">
          <view class="food-image-wrap">
            <view class="food-image-placeholder">{{item.icon || '🍽️'}}</view>
            <view class="food-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
          </view>
          <view class="food-info">
            <view class="food-name">{{item.name}}</view>
            <view class="food-desc">{{item.desc}}</view>
            <view class="food-bottom">
              <view class="food-price">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.price}}</text>
                <text class="price-old" wx:if="{{item.originalPrice > item.price}}">¥{{item.originalPrice}}</text>
              </view>
              <view class="food-meta">
                <text class="food-rating">⭐ {{item.rating}}</text>
                <text class="food-sales">已售 {{item.sales}}</text>
              </view>
            </view>
          </view>
          <view class="add-btn" catchtap="addToCart" data-id="{{item.id}}">+</view>
        </view>
      </block>

      <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
        <text>加载更多 ↓</text>
      </view>
    </view>
  </view>

</view>
