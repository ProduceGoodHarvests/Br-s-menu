.checkout-page {
  min-height: 100vh;
  padding: 16rpx 0 150rpx;
  background: #f6f7fb;
}

.section,
.total-section {
  margin: 0 16rpx 14rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.04);
}

.section-title {
  margin-bottom: 18rpx;
  padding-left: 14rpx;
  border-left: 6rpx solid #ff6a2a;
  color: #1f2329;
  font-size: 29rpx;
  font-weight: 700;
}

.table-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.table-item {
  width: calc((100% - 14rpx) / 2);
  min-height: 92rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #f1f3f7;
  border: 2rpx solid transparent;
}

.table-item.active {
  background: #fff0e8;
  border-color: #ff6a2a;
}

.table-name {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 700;
}

.table-area {
  margin-top: 6rpx;
  color: #8a8f99;
  font-size: 23rpx;
}

.table-item.active .table-name,
.table-item.active .table-area {
  color: #ff6a2a;
}

.item-list {
  border-top: 1rpx solid #eef0f4;
}

.item {
  min-height: 86rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef0f4;
}

.item:last-child {
  border-bottom: none;
}

.item-left {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 700;
}

.item-specs {
  margin-top: 6rpx;
  color: #8a8f99;
  font-size: 22rpx;
  line-height: 32rpx;
}

.item-right {
  margin-left: 20rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.item-qty {
  color: #8a8f99;
  font-size: 24rpx;
}

.item-price {
  min-width: 112rpx;
  text-align: right;
  color: #ff6a2a;
  font-size: 30rpx;
  font-weight: 800;
}

.remark-input {
  width: 100%;
  min-height: 138rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f1f3f7;
  color: #1f2329;
  font-size: 26rpx;
  line-height: 38rpx;
}

.total-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-label {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
}

.total-price {
  color: #ff6a2a;
  font-size: 44rpx;
  font-weight: 800;
}

.submit-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6a2a;
  color: #fff;
  font-size: 31rpx;
  font-weight: 800;
}

.submit-btn[disabled] {
  opacity: 0.55;
}
