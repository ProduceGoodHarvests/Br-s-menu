/* pages/checkout/checkout.wxss */

.checkout-page { background: #f8f8f8; min-height: 100vh; padding-bottom: 140rpx; }
.section { background: #fff; margin: 0 16rpx 12rpx; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; padding-left: 12rpx; border-left: 6rpx solid #ff5000; }

.table-list { display: flex; flex-wrap: wrap; gap: 14rpx; }
.table-item { display: flex; flex-direction: column; align-items: center; padding: 22rpx 32rpx; border-radius: 14rpx; background: #f8f8f8; border: 2rpx solid transparent; }
.table-item.active { background: #fff5f0; border-color: #ff5000; }
.table-name { font-size: 28rpx; font-weight: 600; color: #333; }
.table-area { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.table-item.active .table-name, .table-item.active .table-area { color: #ff5000; }

.item-list { border-top: 1rpx solid #f5f5f5; }
.item { display: flex; justify-content: space-between; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.item:last-child { border-bottom: none; }
.item-left { flex: 1; }
.item-name { font-size: 28rpx; font-weight: 500; color: #333; }
.item-specs { font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
.item-right { display: flex; align-items: center; gap: 16rpx; }
.item-price { color: #ff5000; font-size: 30rpx; font-weight: 700; }
.item-qty { color: #bbb; font-size: 24rpx; }

.remark-input { width: 100%; height: 120rpx; background: #f8f8f8; border-radius: 12rpx; padding: 16rpx; font-size: 26rpx; box-sizing: border-box; }

.total-section { background: #fff; margin: 12rpx 16rpx; border-radius: 16rpx; padding: 28rpx 24rpx; display: flex; justify-content: space-between; align-items: center; }
.total-label { font-size: 30rpx; font-weight: 600; }
.total-price { font-size: 44rpx; color: #ff5000; font-weight: 700; }

.submit-area { position: fixed; bottom: 0; left: 0; right: 0; padding: 12rpx 24rpx 32rpx; background: #fff; }
.submit-btn { width: 100%; height: 92rpx; background: linear-gradient(135deg, #ff5000, #ff7b33); color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 46rpx; display: flex; align-items: center; justify-content: center; border: none; box-shadow: 0 6rpx 20rpx rgba(255,80,0,0.3); }
.submit-btn[disabled] { opacity: 0.5; }
