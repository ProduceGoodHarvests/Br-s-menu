.mine-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.user-section {
  padding: 48rpx 30rpx 52rpx;
  background: linear-gradient(135deg, #ff6a2a 0%, #ff9f4a 100%);
}

.user-card {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 126rpx;
  height: 126rpx;
  margin-right: 24rpx;
  border-radius: 63rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.24);
  border: 4rpx solid rgba(255, 255, 255, 0.42);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  color: #fff;
  font-size: 58rpx;
}

.user-info {
  min-width: 0;
  flex: 1;
}

.nickname {
  max-width: 440rpx;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-line {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
}

.login-bar {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.role-tag,
.login-btn,
.logout-btn {
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.22);
}

.logout-btn {
  background: rgba(31, 35, 41, 0.14);
}

.stats-section {
  margin: -24rpx 18rpx 16rpx;
  padding: 26rpx 0;
  border-radius: 8rpx;
  display: flex;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.08);
}

.stat-item {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 16rpx;
  width: 1rpx;
  height: 54rpx;
  background: #eef0f4;
}

.stat-value {
  color: #ff6a2a;
  font-size: 42rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 6rpx;
  color: #8a8f99;
  font-size: 23rpx;
}

.menu-section {
  margin: 0 18rpx 24rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.04);
}

.menu-item {
  min-height: 92rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eef0f4;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.role-switch {
  background: #fff0e8;
}

.menu-icon {
  width: 48rpx;
  margin-right: 16rpx;
  color: #ff6a2a;
  font-size: 34rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  color: #1f2329;
  font-size: 28rpx;
  font-weight: 600;
}

.menu-arrow {
  color: #c5c9d2;
  font-size: 42rpx;
}
