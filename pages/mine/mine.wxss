/* pages/mine/mine.wxss */

.mine-page { min-height: 100vh; background: #f8f8f8; }

.user-section { background: linear-gradient(160deg, #ff5000 0%, #ff7b33 60%, #ff9a5c 100%); padding: 50rpx 32rpx 52rpx; }
.user-card { display: flex; align-items: center; }
.avatar-wrap { width: 130rpx; height: 130rpx; border-radius: 50%; background: rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; margin-right: 24rpx; overflow: hidden; border: 4rpx solid rgba(255,255,255,0.4); }
.avatar { width: 100%; height: 100%; }
.avatar-placeholder { font-size: 60rpx; }
.user-info { display: flex; flex-direction: column; }
.nickname { font-size: 38rpx; font-weight: 700; color: #fff; margin-bottom: 6rpx; }
.phone { font-size: 26rpx; color: rgba(255,255,255,0.75); }

/* 角色标签 */
.role-tag { margin-top: 20rpx; display: flex; align-items: center; gap: 12rpx; }
.role-tag text:first-child { background: rgba(255,255,255,0.2); color: #fff; padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.role-hint { color: rgba(255,255,255,0.6); font-size: 22rpx; }

.stats-section { display: flex; background: #fff; margin: -20rpx 22rpx 16rpx; border-radius: 18rpx; padding: 28rpx 0; box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.06); }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; }
.stat-item:not(:last-child)::after { content: ''; position: absolute; right: 0; top: 25%; height: 50%; width: 1rpx; background: #eee; }
.stat-value { font-size: 44rpx; font-weight: 700; color: #ff5000; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 6rpx; }

.menu-section { background: #fff; margin: 0 22rpx; border-radius: 18rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.menu-item { display: flex; align-items: center; padding: 32rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-item.role-switch { background: #fff8f5; }
.menu-item.role-switch .menu-text { color: #ff5000; font-weight: 500; }
.menu-icon { font-size: 38rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 36rpx; color: #ddd; }
