<view class="mine-page">
  <view class="user-section">
    <view class="user-card">
      <view class="avatar-wrap" bindtap="onTapAvatar">
        <image class="avatar" wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <text class="avatar-placeholder" wx:else>👤</text>
      </view>
      <view class="user-info">
        <view class="nickname" wx:if="{{isLogin}}">{{userInfo.nickname || '食客'}}</view>
        <view class="nickname" wx:else bindtap="doLogin">点击登录</view>
        <view class="role-line">{{isMerchant ? '商家模式' : '顾客模式'}}</view>
      </view>
    </view>

    <view class="login-bar">
      <view class="role-tag" bindtap="toggleRole">{{isMerchant ? '商家' : '顾客'}}</view>
      <view class="login-btn" wx:if="{{!isLogin}}" bindtap="doLogin">登录</view>
      <view class="logout-btn" wx:if="{{isLogin}}" bindtap="doLogout">退出</view>
    </view>
  </view>

  <view class="stats-section">
    <view class="stat-item" bindtap="goOrders">
      <text class="stat-value">{{orderCount}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-item" bindtap="goOrders">
      <text class="stat-value">{{activeCount}}</text>
      <text class="stat-label">待处理</text>
    </view>
    <view class="stat-item" bindtap="goCart">
      <text class="stat-value">{{cartCount}}</text>
      <text class="stat-label">购物车</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item role-switch" bindtap="toggleRole">
      <text class="menu-icon">⇄</text>
      <text class="menu-text">切换到{{isMerchant ? '顾客模式' : '商家模式'}}</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" wx:if="{{isMerchant}}" bindtap="goMerchant">
      <text class="menu-icon">▣</text>
      <text class="menu-text">商家后台</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goOrders">
      <text class="menu-icon">☷</text>
      <text class="menu-text">{{isMerchant ? '订单处理' : '我的订单'}}</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" wx:if="{{!isMerchant}}" bindtap="goCart">
      <text class="menu-icon">🛒</text>
      <text class="menu-text">购物车</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="aboutUs">
      <text class="menu-icon">i</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
