.legacy-page {
  min-height: 100vh;
  padding: 160rpx 48rpx;
  background: #f6f7fb;
  text-align: center;
}

.legacy-title {
  color: #1f2329;
  font-size: 36rpx;
  font-weight: 800;
}

.legacy-text {
  margin-top: 16rpx;
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 40rpx;
}

.legacy-btn {
  width: 320rpx;
  height: 80rpx;
  margin: 40rpx auto 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ff6a2a;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}
