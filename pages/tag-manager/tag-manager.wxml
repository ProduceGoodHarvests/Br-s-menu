<!--pages/tag-manager/tag-manager.wxml-->
<view class="tag-page">
  <view class="summary-panel">
    <view class="summary-left">
      <text class="summary-title">标签库</text>
      <text class="summary-count">{{tags.length}} 个标签</text>
    </view>
    <view class="reset-btn" bindtap="resetTags">恢复默认</view>
  </view>

  <view class="add-panel">
    <input
      class="tag-input"
      placeholder="新增标签"
      maxlength="8"
      value="{{newTag}}"
      bindinput="onTagInput"
      confirm-type="done"
      bindconfirm="addTag"
    />
    <view class="add-btn" bindtap="addTag">添加</view>
  </view>

  <view class="tag-list" wx:if="{{tagItems.length > 0}}">
    <view
      class="tag-card"
      wx:for="{{tagItems}}"
      wx:key="name"
      style="animation-delay: {{index * 28}}ms"
    >
      <view class="tag-main">
        <text class="tag-name">#{{item.name}}</text>
        <text class="tag-count">{{item.count}} 个菜</text>
      </view>
      <view class="delete-btn" catchtap="deleteTag" data-name="{{item.name}}">删除</view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-icon">🏷️</text>
    <text class="empty-text">暂无标签</text>
  </view>
</view>
