<view class="cart-page">
  <view wx:if="{{isEmpty}}" class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-title">购物车是空的</text>
    <text class="empty-text">先去挑几道喜欢的菜</text>
    <view class="empty-btn" bindtap="goOrder">去点餐</view>
  </view>

  <view wx:else class="cart-content">
    <view class="cart-list">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="specKey">
        <view class="check-wrap" bindtap="toggleCheck" data-index="{{index}}">
          <view class="check-box {{item.checked ? 'checked' : ''}}">
            <text wx:if="{{item.checked}}">✓</text>
          </view>
        </view>

        <view class="item-image">{{item.icon || '🍽️'}}</view>

        <view class="item-info">
          <view class="item-name">{{item.name}}</view>
          <view class="item-specs" wx:if="{{item.specs && item.specs.length > 0}}">
            <text wx:for="{{item.specs}}" wx:key="name" wx:for-item="spec">
              {{spec.name}}：{{spec.value}} 
            </text>
          </view>
          <view class="item-bottom">
            <view class="item-price">¥{{item.priceText}}</view>
            <view class="item-qty-control">
              <view class="qty-btn" catchtap="changeQty" data-index="{{index}}" data-action="minus">−</view>
              <text class="qty-value">{{item.quantity}}</text>
              <view class="qty-btn" catchtap="changeQty" data-index="{{index}}" data-action="plus">+</view>
            </view>
          </view>
        </view>

        <view class="item-delete" catchtap="deleteItem" data-index="{{index}}">×</view>
      </view>
    </view>

    <view class="bottom-bar safe-bottom">
      <view class="bottom-left" bindtap="toggleAll">
        <view class="check-box {{allChecked ? 'checked' : ''}}">
          <text wx:if="{{allChecked}}">✓</text>
        </view>
        <text class="check-all-text">全选</text>
      </view>
      <view class="bottom-right">
        <view class="total-info">
          <text class="total-label">合计</text>
          <text class="total-price">¥{{totalPrice}}</text>
        </view>
        <view class="checkout-btn" bindtap="checkout">结算 {{checkedCount}}</view>
      </view>
    </view>
  </view>
</view>
