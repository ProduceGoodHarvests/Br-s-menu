<!--pages/cart/cart.wxml-->
<view class="cart-page">

  <!-- 空购物车 -->
  <view wx:if="{{isEmpty}}" class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空的</text>
    <view class="empty-btn" bindtap="goOrder">去点餐</view>
  </view>

  <!-- 购物车列表 -->
  <view wx:else class="cart-content">
    <view class="cart-list">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="*this">
        <!-- 选择框 -->
        <view class="check-wrap" bindtap="toggleCheck" data-index="{{index}}">
          <view class="check-box {{item.checked ? 'checked' : ''}}">
            <text wx:if="{{item.checked}}">✓</text>
          </view>
        </view>

        <!-- 商品信息 -->
        <view class="item-image-wrap">
          <view class="item-image-placeholder">{{item.icon || '🍽️'}}</view>
        </view>
        <view class="item-info">
          <view class="item-name">{{item.name}}</view>
          <view class="item-specs" wx:if="{{item.specs && item.specs.length > 0}}">
            <text wx:for="{{item.specs}}" wx:key="name" wx:for-item="spec">{{spec.name}}：{{spec.value}} </text>
          </view>
          <view class="item-bottom">
            <view class="item-price">¥{{item.price}}</view>
            <view class="item-qty-control">
              <view class="qty-btn" bindtap="changeQty" data-index="{{index}}" data-action="minus">−</view>
              <text class="qty-value">{{item.quantity}}</text>
              <view class="qty-btn" bindtap="changeQty" data-index="{{index}}" data-action="plus">+</view>
            </view>
          </view>
        </view>

        <!-- 删除 -->
        <view class="item-delete" bindtap="deleteItem" data-index="{{index}}">
          <text>🗑️</text>
        </view>
      </view>
    </view>

    <!-- 底部结算栏 -->
    <view class="bottom-bar">
      <view class="bottom-left" bindtap="toggleAll">
        <view class="check-box {{allChecked ? 'checked' : ''}}">
          <text wx:if="{{allChecked}}">✓</text>
        </view>
        <text class="check-all-text">全选</text>
      </view>
      <view class="bottom-right">
        <view class="total-info">
          <text class="total-label">合计：</text>
          <text class="total-price">¥{{totalPrice}}</text>
        </view>
        <view class="checkout-btn" bindtap="checkout">去结算</view>
      </view>
    </view>
  </view>

</view>
