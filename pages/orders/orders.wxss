.orders-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.role-banner {
  padding: 14rpx 24rpx;
  background: #1f6feb;
  color: #fff;
  font-size: 25rpx;
  text-align: center;
}

.tab-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  padding: 0 28rpx;
  background: #fff;
  box-shadow: 0 1rpx 0 rgba(31, 35, 41, 0.06);
}

.tab-item {
  flex: 1;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  color: #8a8f99;
  font-size: 28rpx;
}

.tab-item.active {
  color: #ff6a2a;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 52rpx;
  height: 4rpx;
  border-radius: 2rpx;
  transform: translateX(-50%);
  background: #ff6a2a;
}

.order-list {
  padding: 16rpx 16rpx 24rpx;
}

.order-card {
  margin-bottom: 14rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 6rpx 18rpx rgba(31, 35, 41, 0.04);
}

.order-header,
.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-header {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eef0f4;
}

.order-id {
  max-width: 480rpx;
  color: #8a8f99;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.order-status.pending {
  background: #fff4d6;
  color: #9a6500;
}

.order-status.confirmed {
  background: #e8f1ff;
  color: #1f6feb;
}

.order-status.completed {
  background: #e8f7ee;
  color: #16833a;
}

.order-body {
  padding: 12rpx 0;
}

.order-item {
  min-height: 50rpx;
  display: flex;
  align-items: center;
}

.order-food-name {
  flex: 1;
  color: #1f2329;
  font-size: 27rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-food-qty {
  width: 74rpx;
  color: #8a8f99;
  font-size: 24rpx;
  text-align: center;
}

.order-food-price {
  width: 126rpx;
  color: #5f6570;
  font-size: 26rpx;
  text-align: right;
}

.order-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #eef0f4;
}

.order-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.order-table {
  color: #1f2329;
  font-size: 26rpx;
  font-weight: 700;
}

.order-time {
  margin-top: 6rpx;
  color: #8a8f99;
  font-size: 22rpx;
}

.order-total {
  margin-left: 18rpx;
  color: #5f6570;
  font-size: 24rpx;
  flex-shrink: 0;
}

.total-amount {
  color: #ff6a2a;
  font-size: 30rpx;
  font-weight: 800;
}

.remark {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: #f6f7fb;
  color: #5f6570;
  font-size: 24rpx;
  line-height: 36rpx;
}

.merchant-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  display: flex;
  gap: 14rpx;
  border-top: 1rpx solid #eef0f4;
}

.btn-confirm,
.btn-complete {
  flex: 1;
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-confirm {
  background: #ff6a2a;
}

.btn-complete {
  background: #16833a;
}
