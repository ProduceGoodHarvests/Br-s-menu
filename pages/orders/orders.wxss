/* pages/orders/orders.wxss */

.orders-page { min-height: 100vh; background: #f8f8f8; }
.tab-bar { display: flex; background: #fff; padding: 0 32rpx; position: sticky; top: 0; z-index: 50; }
.tab-item { flex: 1; text-align: center; padding: 26rpx 0; font-size: 28rpx; color: #888; position: relative; }
.tab-item.active { color: #ff5000; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 56rpx; height: 4rpx; background: #ff5000; border-radius: 2rpx; }

.order-list { padding: 16rpx 20rpx; }
.order-card { background: #fff; border-radius: 18rpx; padding: 22rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }
.order-header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 14rpx; border-bottom: 1rpx solid #f5f5f5; }
.order-id { font-size: 24rpx; color: #bbb; }
.order-status { font-size: 24rpx; padding: 6rpx 18rpx; border-radius: 20rpx; font-weight: 500; }
.order-status.pending { background: #fff3e6; color: #ff8c00; }
.order-status.completed { background: #e8f8e8; color: #1aad19; }
.order-body { padding: 14rpx 0; }
.order-item { display: flex; align-items: center; padding: 10rpx 0; }
.order-food-name { flex: 1; font-size: 27rpx; color: #333; font-weight: 500; }
.order-food-qty { font-size: 24rpx; color: #bbb; margin: 0 16rpx; }
.order-food-price { font-size: 27rpx; color: #666; }
.order-footer { display: flex; align-items: center; padding-top: 14rpx; border-top: 1rpx solid #f5f5f5; font-size: 22rpx; color: #bbb; }
.order-table { margin-right: 16rpx; }
.order-time { flex: 1; }
.order-total { font-size: 24rpx; color: #333; }
.total-amount { color: #ff5000; font-weight: 700; font-size: 28rpx; }
