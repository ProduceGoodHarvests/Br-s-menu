<view class="orders-page">
  <view class="role-banner" wx:if="{{isMerchant}}">
    商家模式：可在订单卡片中接单和完成出餐
  </view>

  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === item.value ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="value"
      bindtap="onTabTap"
      data-value="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{isEmpty}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无订单</text>
    <text class="empty-text">订单提交后会显示在这里</text>
  </view>

  <view wx:else class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-header" bindtap="showDetail" data-index="{{index}}">
        <text class="order-id">订单号：{{item.id}}</text>
        <text class="order-status {{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="order-body" bindtap="showDetail" data-index="{{index}}">
        <view class="order-item" wx:for="{{item.items}}" wx:key="name" wx:for-item="food">
          <text class="order-food-name">{{food.name}}</text>
          <text class="order-food-qty">x{{food.quantity}}</text>
          <text class="order-food-price">¥{{food.subtotal}}</text>
        </view>
      </view>

      <view class="order-footer">
        <view class="order-main">
          <text class="order-table">{{item.table}}</text>
          <text class="order-time">{{item.createTime}}</text>
        </view>
        <view class="order-total">
          <text>合计 </text>
          <text class="total-amount">¥{{item.totalPrice}}</text>
        </view>
      </view>

      <view class="remark" wx:if="{{item.remark}}">备注：{{item.remark}}</view>

      <view class="merchant-actions" wx:if="{{isMerchant && item.status !== 'completed'}}">
        <button class="btn-confirm" wx:if="{{item.status === 'pending'}}" bindtap="confirmOrder" data-id="{{item.id}}">接单制作</button>
        <button class="btn-complete" wx:if="{{item.status === 'confirmed'}}" bindtap="completeOrder" data-id="{{item.id}}">完成出餐</button>
      </view>
    </view>
  </view>
</view>
