.data-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 22rpx 40rpx;
  background: #f8f8f8;
}

.sync-panel,
.stats-panel,
.actions-panel {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 18rpx;
  padding: 26rpx 24rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.panel-title {
  color: #222;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.panel-subtitle {
  color: #888;
  font-size: 24rpx;
  margin-top: 8rpx;
  word-break: break-all;
}

.status-pill {
  flex-shrink: 0;
  min-width: 112rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
  color: #666;
  background: #f2f2f2;
}

.status-synced { color: #137333; background: #e7f5ea; }
.status-syncing { color: #8a4b00; background: #fff2d9; }
.status-pending { color: #b45f06; background: #fff2d9; }
.status-error { color: #b3261e; background: #fde8e7; }
.status-local { color: #555; background: #eeeeee; }

.sync-desc {
  color: #555;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 22rpx;
}

.sync-meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #888;
  font-size: 24rpx;
  line-height: 1.4;
  margin-top: 18rpx;
}

.sync-error {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  color: #b3261e;
  background: #fde8e7;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.stat-cell {
  min-height: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #fafafa;
}

.stat-value {
  color: #ff5000;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.1;
}

.stat-label {
  color: #888;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.actions-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e6e6e6;
  color: #333;
  background: #fff;
  font-size: 28rpx;
  line-height: 84rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  border-color: #ff5000;
  color: #fff;
  background: #ff5000;
}

.action-btn.danger {
  border-color: #f4c7c3;
  color: #b3261e;
  background: #fff8f7;
}

.action-btn[disabled] {
  color: #aaa;
  background: #f4f4f4;
  border-color: #eeeeee;
}
