.detail-page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f6f7fb;
}

.food-hero {
  height: 340rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.hero-emoji {
  font-size: 92rpx;
  line-height: 1;
}

.hero-cat {
  margin-top: 18rpx;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #5f6570;
  font-size: 24rpx;
}

.info-section,
.price-section,
.spec-section,
.qty-section,
.detail-section {
  background: #fff;
}

.info-section {
  position: relative;
  z-index: 2;
  margin-top: -22rpx;
  padding: 30rpx 24rpx 22rpx;
  border-radius: 8rpx 8rpx 0 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.food-title {
  flex: 1;
  color: #1f2329;
  font-size: 40rpx;
  font-weight: 800;
}

.food-tag {
  padding: 5rpx 12rpx;
  border-radius: 6rpx;
  background: #fff0e8;
  color: #ff6a2a;
  font-size: 22rpx;
  font-weight: 600;
}

.food-desc {
  margin-top: 14rpx;
  color: #5f6570;
  font-size: 27rpx;
  line-height: 42rpx;
}

.food-stats {
  margin-top: 14rpx;
  display: flex;
  gap: 26rpx;
  color: #8a8f99;
  font-size: 24rpx;
}

.price-section {
  padding: 0 24rpx 28rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
}

.symbol {
  color: #ff6a2a;
  font-size: 30rpx;
  font-weight: 700;
}

.current-price {
  color: #ff6a2a;
  font-size: 56rpx;
  font-weight: 800;
}

.original-price {
  margin-left: 14rpx;
  color: #a8adb7;
  font-size: 26rpx;
  text-decoration: line-through;
}

.unit-price {
  display: block;
  margin-top: 4rpx;
  color: #8a8f99;
  font-size: 24rpx;
}

.spec-section {
  margin-top: 12rpx;
  padding: 24rpx;
}

.spec-section + .spec-section {
  margin-top: 0;
  border-top: 1rpx solid #eef0f4;
}

.spec-title,
.section-label {
  color: #1f2329;
  font-size: 29rpx;
  font-weight: 700;
}

.spec-options {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.spec-option {
  min-width: 112rpx;
  height: 62rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f3f7;
  border: 2rpx solid transparent;
  color: #5f6570;
  font-size: 26rpx;
}

.spec-option.active {
  background: #fff0e8;
  border-color: #ff6a2a;
  color: #ff6a2a;
  font-weight: 700;
}

.qty-section,
.detail-section {
  margin: 12rpx 16rpx 0;
  padding: 26rpx 24rpx;
  border-radius: 8rpx;
}

.qty-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f3f7;
  color: #1f2329;
  font-size: 36rpx;
}

.qty-btn.disabled {
  color: #c5c9d2;
}

.qty-value {
  width: 90rpx;
  text-align: center;
  color: #1f2329;
  font-size: 34rpx;
  font-weight: 800;
}

.detail-line {
  margin-top: 14rpx;
  color: #5f6570;
  font-size: 26rpx;
  line-height: 40rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #fff;
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.08);
}

.cart-entry {
  width: 82rpx;
  height: 82rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #f1f3f7;
  font-size: 38rpx;
}

.btn-add-cart,
.btn-buy-now {
  flex: 1;
  height: 82rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 700;
}

.btn-add-cart {
  background: #fff0e8;
  color: #ff6a2a;
}

.btn-buy-now {
  background: #ff6a2a;
  color: #fff;
}

.c-1 {
  background: #ffe7dc;
}

.c-2 {
  background: #e4f3ff;
}

.c-3 {
  background: #e8f5e9;
}

.c-4 {
  background: #fff4c6;
}
