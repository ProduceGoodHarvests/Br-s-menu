/* pages/add-dish/add-dish.wxss */

.add-page { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }

.form-section { background: #fff; border-radius: 20rpx; padding: 28rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.03); }
.form-title { font-size: 32rpx; font-weight: 700; margin-bottom: 28rpx; color: #222; }

.form-item { margin-bottom: 24rpx; }
.label { font-size: 26rpx; color: #888; margin-bottom: 10rpx; display: block; }
.input { width: 100%; height: 80rpx; background: #f8f8f8; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; }

.cat-select { display: flex; flex-wrap: wrap; gap: 12rpx; }
.cat-opt { padding: 12rpx 18rpx; background: #f8f8f8; border-radius: 10rpx; font-size: 24rpx; border: 2rpx solid transparent; }
.cat-opt.active { background: #fff5f0; border-color: #ff5000; color: #ff5000; }

.submit-btn { width: 100%; height: 88rpx; background: linear-gradient(135deg, #ff5000, #ff7b33); color: #fff; font-size: 30rpx; font-weight: 600; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; border: none; margin-top: 8rpx; box-shadow: 0 6rpx 20rpx rgba(255,80,0,0.25); }

/* 我的菜品 */
.list-section { background: #fff; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.02); }
.list-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; color: #222; }

.my-dish { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.my-dish:last-child { border-bottom: none; }
.dish-left { display: flex; align-items: center; }
.dish-icon { width: 70rpx; height: 70rpx; border-radius: 14rpx; background: #fff5f0; display: flex; align-items: center; justify-content: center; font-size: 34rpx; margin-right: 16rpx; }
.dish-info { display: flex; flex-direction: column; }
.dish-name { font-size: 28rpx; font-weight: 500; color: #333; }
.dish-price { font-size: 26rpx; color: #ff5000; font-weight: 600; margin-top: 4rpx; }
.dish-del { width: 48rpx; height: 48rpx; border-radius: 50%; background: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #999; }
