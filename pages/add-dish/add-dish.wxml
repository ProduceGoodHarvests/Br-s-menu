<!--pages/add-dish/add-dish.wxml-->
<view class="add-page">
  <view class="form-section page-fade">
    <view class="form-head">
      <view class="form-title">➕ 添加新菜品</view>
      <view class="manage-tag-btn" bindtap="goTagManager">标签管理</view>
    </view>

    <view class="form-item">
      <text class="label">菜品名称</text>
      <input class="input" placeholder="如：青椒炒肉" value="{{name}}" bindinput="onNameInput"/>
    </view>

    <view class="form-item">
      <text class="label">价格 (¥)</text>
      <input class="input" type="digit" placeholder="如：26" value="{{price}}" bindinput="onPriceInput"/>
    </view>

    <view class="form-item">
      <text class="label">分类</text>
      <view class="cat-select">
        <view class="cat-opt {{categoryIndex === index ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" wx:for-index="index" bindtap="selectCategory" data-index="{{index}}">
          <text>{{item.icon}} {{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="label">标签</text>
      <view class="tag-select">
        <view class="tag-opt {{tag === item ? 'active' : ''}}" wx:for="{{tags}}" wx:key="*this" bindtap="selectTag" data-tag="{{item}}">#{{item}}</view>
      </view>
      <input class="input tag-input" placeholder="也可以手动输入新标签" value="{{tag}}" bindinput="onTagInput"/>
    </view>

    <button class="submit-btn" bindtap="addDish">确认添加</button>
  </view>

  <view class="list-section" wx:if="{{myDishes.length > 0}}">
    <view class="list-title">📋 我的菜品 ({{myDishes.length}})</view>
    <view class="my-dish" wx:for="{{myDishes}}" wx:key="i" style="animation-delay: {{index * 28}}ms">
      <view class="dish-left">
        <view class="dish-icon"><text>{{item.e}}</text></view>
        <view class="dish-info">
          <text class="dish-name">{{item.n}}</text>
          <text class="dish-price">¥{{item.p}} <text wx:if="{{item.t}}" class="dish-tag">#{{item.t}}</text></text>
        </view>
      </view>
      <view class="dish-del" bindtap="deleteDish" data-index="{{index}}">✕</view>
    </view>
  </view>
</view>
